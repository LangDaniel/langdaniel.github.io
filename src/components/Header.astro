---
---

<header>
  <nav>
    <div class="nav-brand">Daniel M. Lang</div>
    <ul>
      <li><a href="#about">About</a></li>
      <li><a href="#publications">Publications</a></li>
      <li><a href="#resume">Resume</a></li>
    </ul>
    <div class="nav-actions">
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
        <i class="sun-icon fas fa-sun"></i>
        <i class="moon-icon fas fa-moon"></i>
      </button>
    </div>
  </nav>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  header {
    background-color: #ffffff;
    padding: 1.5rem 0;
    font-family: 'Inter', sans-serif;
    transition: all 0.3s ease;
  }

  header.dark-mode {
    background-color: #0f172a;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .nav-brand {
    font-size: 1.4rem;
    font-weight: 600;
    color: #1f2937;
    letter-spacing: -0.5px;
  }

  header.dark-mode .nav-brand {
    color: #00ff88;
  }

  ul {
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  a {
    text-decoration: none;
    color: #6b7280;
    font-weight: 400;
    font-size: 0.95rem;
    transition: color 0.3s ease;
    position: relative;
  }

  header.dark-mode a {
    color: #00ff88;
  }

  a:hover {
    color: #1f2937;
  }

  header.dark-mode a:hover {
    color: #00ffaa;
  }

  .nav-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    transition: color 0.3s ease;
    padding: 0;
  }

  header.dark-mode .social-link {
    color: #00ff88;
  }

  .social-link:hover {
    color: #1f2937;
  }

  header.dark-mode .social-link:hover {
    color: #00ffaa;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color 0.3s ease;
    color: #6b7280;
  }

  header.dark-mode .theme-toggle {
    color: #00ff88;
  }

  .theme-toggle:hover {
    color: #1f2937;
  }

  header.dark-mode .theme-toggle:hover {
    color: #00ffaa;
  }

  .sun-icon {
    display: none;
  }

  .moon-icon {
    display: block;
  }

  header.dark-mode .sun-icon {
    display: block;
  }

  header.dark-mode .moon-icon {
    display: none;
  }
</style>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const header = document.querySelector('header');

  // Initialize theme from localStorage or default to light
  const savedTheme = localStorage.getItem('theme') || 'light';
  setTheme(savedTheme);

  themeToggle?.addEventListener('click', () => {
    const currentTheme = html.getAttribute('data-theme') || 'light';
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    setTheme(newTheme);
    localStorage.setItem('theme', newTheme);
  });

  function setTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    if (theme === 'dark') {
      header?.classList.add('dark-mode');
      document.body.classList.add('dark-mode');
    } else {
      header?.classList.remove('dark-mode');
      document.body.classList.remove('dark-mode');
    }
  }
</script>
